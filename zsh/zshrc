# zsh
export PATH="$HOME/.local/bin:$PATH"
export ZSH=$HOME/.oh-my-zsh

ZSH_THEME="ys"
plugins=(poetry kube-ps1 kubectl npm docker docker-machine docker-compose dotenv brew osx asdf pip extract z.lua zsh-syntax-highlighting zsh-completions zsh-autosuggestions)

source $ZSH/oh-my-zsh.sh

# export
export LC_ALL="en_US.UTF-8"
export EDITOR="vim"
export HOMEBREW_BOTTLE_DOMAIN="https://mirrors.tuna.tsinghua.edu.cn/homebrew-bottles"
export JAVA_HOME=$(asdf where java)
export GPG_TTY=$(tty)

# source
test -e "${HOME}/.alias" && source "${HOME}/.alias"
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"
test -e "${HOME}/.ghcup/env" && source "${HOME}/.ghcup/env"

# prompt
PROMPT='$(kube_ps1)'$PROMPT

# completions
autoload bashcompinit
bashcompinit
eval "$(register-python-argcomplete pipx)"
source <(kompose completion zsh)
