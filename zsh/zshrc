export ZSH=$HOME/.oh-my-zsh
ZSH_THEME="ys"
plugins=(httpie dotenv brew osx asdf git pip extract z zsh-syntax-highlighting zsh-completions zsh-autosuggestions)
export EDITOR='vim'
export LC_ALL="en_US.UTF-8"
source $ZSH/oh-my-zsh.sh

if [[ -e ~/.alias ]]; then
    source ~/.alias
fi

if [[ -e `pwd`/venv/bin/activate ]]; then
    source `pwd`/venv/bin/activate
elif pipenv --venv &>/dev/null; then
    source `pipenv --venv`/bin/activate
fi

eval "$(pipenv --completion)"

