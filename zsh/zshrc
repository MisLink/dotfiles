# zsh
export PATH="$HOME/.local/bin:$PATH"
export ZSH=$HOME/.oh-my-zsh

ZSH_THEME="ys"
plugins=(kube-ps1 kubectl npm docker docker-machine docker-compose dotenv brew osx asdf pip extract z.lua zsh-syntax-highlighting zsh-completions zsh-autosuggestions)

. $ZSH/oh-my-zsh.sh

# export
export LC_ALL="en_US.UTF-8"
export EDITOR="vim"
export HOMEBREW_BOTTLE_DOMAIN="https://mirrors.tuna.tsinghua.edu.cn/homebrew-bottles"

# source
[ -e ~/.alias ] && . ~/.alias

# prompt
PROMPT='$(kube_ps1)'$PROMPT
