alias del='trash -v'
alias grep='grep -E'
alias df='df -h'
alias du='du -h'
alias j='z'
alias ss-on='export http_proxy=127.0.0.1:1087;export https_proxy=$http_proxy'
alias ss-off='unset http_proxy;unset https_proxy'
alias pip-update="pip list --outdated --format=freeze | grep -v '^\-e' | cut -d = -f 1 | xargs -n1 pip install -U"
alias pip-remove="pip freeze | grep -v "^-e" | xargs pip uninstall -y"

if which vim &>/dev/null; then
    alias vi='vim'
fi
