alias del='trash -v'
alias grep='grep -E'
alias df='df -h'
alias du='du -h'
alias ss-on='export http_proxy=127.0.0.1:1087;export https_proxy=$http_proxy'
alias ss-off='unset http_proxy;unset https_proxy'

if which vim &>/dev/null; then
    alias vi='vim'
fi

alias pip2_update='pip2 list --outdated --format=freeze | grep -v '^\-e' | cut -d = -f 1 | xargs -n1 pip2 install -U'
alias pip3_update='pip3 list --outdated --format=freeze | grep -v '^\-e' | cut -d = -f 1 | xargs -n1 pip3 install -U'

