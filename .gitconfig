[user]
	name = MisLink
	email = gjq.uoiai@outlook.com
[core]
	editor = vim
	excludesfile = C:\\Users\\gjquo\\.gitignore
	autocrlf = false
    quotepath = false
[diff]
	tool = default-difftool
[difftool "default-difftool"]
	cmd = code --wait --diff $LOCAL $REMOTE
[alias]
	l = log --graph --decorate --date=format:'%Y-%m-%d %H:%M:%S' --abbrev-commit --pretty=format:'%C(red)%h%C(reset) - %C(green)(%cd)%C(reset) %s %C(bold blue)<%an(%ae)>%C(reset)%C(yellow)%d%C(reset)' --all
