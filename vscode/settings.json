// 将设置放入此文件中以覆盖默认设置
{
    // editor
    "editor.fontSize": 18,
    "editor.fontFamily": "Inziu Iosevka SC, monospace",
    "editor.renderWhitespace": "all",
    "editor.wordWrap": "on",
    "editor.roundedSelection": false,
    "editor.wrappingIndent": "indent",
    "editor.formatOnType": true,
    "editor.cursorBlinking": "expand",
    "editor.renderIndentGuides": true,
    "editor.renderLineHighlight": "all",
    "editor.rulers": [
        80,
        120
    ],
    "editor.quickSuggestions": {
        "other": true,
        "comments": true,
        "strings": true
    },
    "editor.formatOnSave": true,
    "editor.minimap.enabled": true,
    "diffEditor.ignoreTrimWhitespace": false,
    // window
    "window.reopenFolders": "all",
    "window.newWindowDimensions": "inherit",
    "window.openFoldersInNewWindow": "on",
    // files
    "files.autoGuessEncoding": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.autoSave": "onFocusChange",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/__pycache__": true,
        "**/*.pyc": true
    },
    // debug
    "debug.inlineValues": true,
    // Terminal
    "terminal.integrated.shell.windows": "C:\\WINDOWS\\Sysnative\\WindowsPowerShell\\v1.0\\powershell.exe",
    "terminal.integrated.fontSize": 18,
    "terminal.integrated.scrollback": 99999,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.external.windowsExec": "C:/Program Files/ConEmu/ConEmu64.exe",
    // workbench
    "workbench.experimental.colorCustomizations": {
        // "statusBarBackground": "#393939",
        "panelBackground": "#282c34",
        "sideBarBackground": "#383c44"
    },
    "workbench.activityBar.visible": true,
    "workbench.colorTheme": "Material Theme",
    "workbench.iconTheme": "vscode-icons",
    // vsicons
    "vsicons.dontShowNewVersionMessage": true,
    // Markdown
    "markdown.preview.fontFamily": "Inziu Iosevka SC",
    "markdown.preview.fontSize": 18,
    // JavaScript
    "eslint.autoFixOnSave": true,
    // Docker
    "docker.enableLinting": true,
    "docker.linterRuleFile": "C:/Users/gjquo/docker/basic_rules.yaml",
    // Python
    "python.pythonPath": "C:/Users/gjquo/me/Scripts/python",
    "python.linting.pylintEnabled": false,
    "python.linting.flake8Enabled": true,
    "python.formatting.provider": "yapf",
    "python.formatting.formatOnSave": true,
    "python.workspaceSymbols.ctagsPath": "C:/Users/gjquo/ctags.exe",
    "python.linting.flake8Args": [
        "--ignore",
        "E501"
    ],
    "python.formatting.autopep8Args": [
        "--max-line-length",
        "120"
    ],
    "python.formatting.yapfArgs": [
        "--style",
        "{column_limit: 120}"
    ],
    "python.autoComplete.addBrackets": true,
    // Path intellisense
    "path-intellisense.autoSlashAfterDirectory": true,
    // Setting-Sync
    "sync.gist": "944141e210f0935af6fd52b8c7fe68c5",
    "sync.lastUpload": "2017-04-16T18:06:46.272Z",
    "sync.autoDownload": false,
    "sync.autoUpload": false,
    "sync.lastDownload": "1970-01-01T00:00:00.000Z",
    "sync.version": 262,
    "sync.showSummary": true,
    "sync.forceDownload": false,
    "sync.anonymousGist": false,
    "sync.host": "",
    "sync.pathPrefix": ""
}
